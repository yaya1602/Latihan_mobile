<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F9F4">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tentang Kami"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1E3A5F"
            android:gravity="center"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"/>

        <!-- Deskripsi -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Website Kebencanaan Bina Desa dibuat untuk membantu masyarakat dalam melaporkan, memantau, dan mengelola informasi seputar kejadian bencana di wilayah sekitar."
            android:textSize="14sp"
            android:textColor="#555555"
            android:lineSpacingExtra="4dp"
            android:paddingHorizontal="20dp"
            android:gravity="center"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kami berkomitmen untuk menyediakan informasi yang akurat dan mudah diakses."
            android:textSize="14sp"
            android:textColor="#555555"
            android:paddingHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:gravity="center"/>

        <!-- Card Fitur Utama -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Fitur Utama Sistem"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1E3A5F"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Fitur inti dalam BINA DESA"
                    android:textSize="14sp"
                    android:textColor="#888888"
                    android:gravity="center"
                    android:layout_marginBottom="20dp"/>

                <!-- 3 Fitur -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <!-- Data Warga -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_people"
                            android:contentDescription="Data Warga"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Data Warga"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1E3A5F"
                            android:layout_marginTop="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pendataan informasi warga"
                            android:textSize="11sp"
                            android:textColor="#888888"
                            android:gravity="center"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <!-- Kejadian Bencana -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_warning"
                            android:contentDescription="Bencana"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kejadian Bencana"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1E3A5F"
                            android:layout_marginTop="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Informasi dan laporan bencana"
                            android:textSize="11sp"
                            android:textColor="#888888"
                            android:gravity="center"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <!-- Donasi -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_favorite"
                            android:contentDescription="Donasi"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Donasi"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1E3A5F"
                            android:layout_marginTop="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bantuan untuk korban"
                            android:textSize="11sp"
                            android:textColor="#888888"
                            android:gravity="center"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ✅ BAGIAN GAMBAR (BARU DITAMBAHKAN) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dokumentasi Kegiatan"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1E3A5F"
            android:gravity="center"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="16dp"/>

        <!-- Baris 1: 2 Gambar Besar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:paddingHorizontal="10dp">

            <ImageView
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:src="@drawable/banjir3"
                android:scaleType="centerCrop"
                android:layout_marginEnd="6dp"
                android:background="#E0E0E0"
                android:contentDescription="Kegiatan 1"/>

            <ImageView
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:src="@drawable/kebakaran4"
                android:scaleType="centerCrop"
                android:layout_marginStart="6dp"
                android:background="#E0E0E0"
                android:contentDescription="Kegiatan 2"/>
        </LinearLayout>

        <!-- Baris 2: 3 Gambar Kecil -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:paddingHorizontal="10dp"
            android:layout_marginTop="10dp">

            <ImageView
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:src="@drawable/kebakran2"
                android:scaleType="centerCrop"
                android:layout_marginEnd="4dp"
                android:background="#E0E0E0"
                android:contentDescription="Kegiatan 3"/>

            <ImageView
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:src="@drawable/longsor1"
                android:scaleType="centerCrop"
                android:layout_marginHorizontal="4dp"
                android:background="#E0E0E0"
                android:contentDescription="Kegiatan 4"/>

            <ImageView
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:src="@drawable/longsor3"
                android:scaleType="centerCrop"
                android:layout_marginStart="4dp"
                android:background="#E0E0E0"
                android:contentDescription="Kegiatan 5"/>
        </LinearLayout>

        <!-- Footer / Copyright -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="© 2025 Bina Desa. All Rights Reserved."
            android:textSize="12sp"
            android:textColor="#888888"
            android:gravity="center"
            android:padding="20dp"
            android:layout_marginTop="20dp"/>

    </LinearLayout>
</ScrollView>